          "active_level": "low"
        }
      ]
    },
    {
      "type": "bus",
      "direction": "slave",
      "protocol": "APB",
      "port": "apb",
      "description": "APB slave control interface. Registers: FFT_CTRL (start/reset), FFT_STATUS (busy/done/error), FFT_LENGTH, twiddle write window at offset 0x800.",
      "signals": [
        {
          "name": "pclk_i",
          "direction": "input",
          "type": "clock",
          "width": 1
        },
        {
          "name": "preset_n_i",
          "direction": "input",
          "type": "reset",
          "width": 1,
          "active_level": "low"
        },
        {
          "name": "psel_i",
          "direction": "input",
          "type": "control",
          "width": 1
        },
        {
          "name": "penable_i",
          "direction": "input",
          "type": "control",
          "width": 1
        },
        {
          "name": "pwrite_i",
          "direction": "input",
          "type": "control",
          "width": 1
        },
        {
          "name": "paddr_i",
          "direction": "input",
          "type": "address",
          "width": 16
        },
        {
          "name": "pwdata_i",
          "direction": "input",
          "type": "data",
          "width": 32
        },
        {
          "name": "prdata_o",
          "direction": "output",
          "type": "data",
          "width": 32
        },
        {
          "name": "pready_o",
          "direction": "output",
          "type": "control",
          "width": 1
        }
      ]
    },
    {
      "type": "interrupt",
      "direction": "output",
      "protocol": "level",
      "port": "intr",
      "width": 2,
      "signals": [
        {
          "name": "fft_done_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "FFT computation complete"
        },
        {
          "name": "fft_error_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "FFT error (overflow or configuration)"
        }
      ]
    }
  ],
  "parameters": [
