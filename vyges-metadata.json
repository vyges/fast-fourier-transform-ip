  "name": "fast-fourier-transform-ip",
  "version": "1.0.0",
  "description": "Configurable 1024-point radix-2 decimation-in-frequency FFT accelerator with APB slave control interface, AXI data port (Phase 2), 2048x32-bit internal memory (data + twiddle), pipelined butterfly engine, auto-rescaling, and done/error interrupts. 16-bit fixed-point I/Q. Vyges-original IP.",
  "license": "Apache-2.0",
  "maturity": "production",
  "target": ["asic", "fpga"],
  "design_type": ["digital"],
  "created": "2025-11-01T00:00:00Z",
  "updated": "2026-03-27T19:40:00Z",
  "source": {"type": "git", "url": "https://github.com/vyges/fast-fourier-transform-ip", "private": false, "rtl_path": "rtl"},
  "maintainers": [{"name": "Vyges", "email": "team@vyges.com", "github": "vyges"}],
  "interfaces": [
    {
      "type": "bus", "direction": "slave", "protocol": "APB", "port": "apb",
      "description": "APB slave control interface. Registers: FFT_CTRL (start/reset), FFT_STATUS (busy/done/error), FFT_LENGTH, twiddle write window at offset 0x800.",
      "signals": [
        {"name": "pclk_i", "direction": "input", "type": "clock", "width": 1},
        {"name": "preset_n_i", "direction": "input", "type": "reset", "width": 1, "active_level": "low"},
        {"name": "psel_i", "direction": "input", "type": "control", "width": 1},
        {"name": "penable_i", "direction": "input", "type": "control", "width": 1},
        {"name": "pwrite_i", "direction": "input", "type": "control", "width": 1},
        {"name": "paddr_i", "direction": "input", "type": "address", "width": 16},
        {"name": "pwdata_i", "direction": "input", "type": "data", "width": 32},
        {"name": "prdata_o", "direction": "output", "type": "data", "width": 32},
        {"name": "pready_o", "direction": "output", "type": "control", "width": 1}
      ]
    },
    {
      "type": "interrupt", "direction": "output", "protocol": "level", "port": "intr", "width": 2,
      "signals": [
        {"name": "fft_done_o", "direction": "output", "type": "interrupt", "width": 1, "description": "FFT computation complete"},
        {"name": "fft_error_o", "direction": "output", "type": "interrupt", "width": 1, "description": "FFT error (overflow or configuration)"}
      ]
    }
  ],
  "parameters": [
    {"name": "FFT_MAX_LENGTH_LOG2", "type": "int", "default": 10, "description": "Log2 of max FFT length (10 = 1024-point)"},
    {"name": "FFT_DATA_WIDTH", "type": "int", "default": 16, "description": "I/Q data width in bits"},
    {"name": "FFT_TWIDDLE_WIDTH", "type": "int", "default": 16, "description": "Twiddle factor width in bits"},
    {"name": "FFT_APB_ADDR_WIDTH", "type": "int", "default": 16, "description": "APB address width"},
    {"name": "FFT_AXI_ADDR_WIDTH", "type": "int", "default": 32, "description": "AXI data port address width (Phase 2)"},
    {"name": "FFT_AXI_DATA_WIDTH", "type": "int", "default": 64, "description": "AXI data port width (Phase 2)"}
  ],
  "performance": {
    "frequency": {
      "asic_sky130": "50 MHz (proven, OpenLane hardened)",
      "fpga_artix7": "50 MHz (proven, Arty A7-100T)"
    },
    "fft_cycles": "~6,000 cycles for 1024-point FFT (10 stages x 512 butterflies + overhead)",
    "fft_time_50mhz": "~120 us at 50 MHz",
    "throughput": "1 butterfly per cycle (pipelined datapath)",
    "gate_count": "~5,391 cells / ~13,322 GE (sky130_fd_sc_hd, Yosys)",
    "fpga_luts": "~2,000 LUTs + 2 BRAM36 (Vivado, with BRAM inference fix)"
  },
  "architecture": {
    "type": "accelerator",
    "submodules": ["fft_top (fft_fft_top)", "fft_fft_engine", "fft_fft_control", "fft_memory_interface", "fft_rescale_unit", "fft_scale_factor_tracker", "fft_twiddle_rom"],
    "features": [
      "Radix-2 decimation-in-frequency (DIF) FFT",
      "Configurable FFT length up to 2^FFT_MAX_LENGTH_LOG2 points",
      "16-bit fixed-point I/Q data with auto-rescaling",
      "Pipelined butterfly engine (1 butterfly/cycle)",
      "2048x32-bit internal memory: 1024 data + 512 twiddle + 512 reserved",
      "Twiddle factors loaded by firmware via APB write window (offset 0x800)",
      "Single-port muxed write (engine + APB) for FPGA BRAM inference",
      "APB slave control: FFT_CTRL, FFT_STATUS, FFT_LENGTH registers",
      "AXI data port for DMA sample loading (Phase 2, currently tied off)",
      "Done and error interrupts",
      "ASIC: sky130 SRAM macros (4x sky130_sram_2kbyte_1rw1r_32x512_8)",
      "FPGA: behavioral memory with (* ram_style = block *) for BRAM inference"
    ]
  },
