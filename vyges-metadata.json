      "name": "FFT_AXI_DATA_WIDTH",
      "type": "int",
      "default": 64,
      "description": "AXI data port width (Phase 2)"
    }
  ],
  "registers": [
    {
      "name": "FFT_CTRL",
      "offset": "0x0000",
      "access": "RW",
